<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job Offers Manager</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #1e3a5f;
      --blue-light: #2a5080;
      --blue-hover: #163049;
      --bg: #f4f6f9;
      --card-bg: #ffffff;
      --text: #1a1a2e;
      --text-muted: #6b7280;
      --border: #e2e8f0;
      --warning: #e53e3e;
      --success: #2f855a;
      --radius: 12px;
      --shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      background: var(--blue);
      color: #fff;
      padding: 32px 24px 28px;
      text-align: center;
    }
    header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }
    header p {
      font-size: 0.95rem;
      opacity: 0.8;
      font-weight: 400;
    }

    /* ── MAIN CONTAINER ── */
    .container {
      max-width: 820px;
      margin: 0 auto;
      padding: 28px 20px 48px;
    }

    /* ── NOTICE ── */
    .notice {
      background: #fff8e6;
      border: 1.5px solid #f0c040;
      border-radius: var(--radius);
      padding: 12px 18px;
      font-size: 0.88rem;
      color: #7a5c00;
      margin-bottom: 24px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
    }
    .notice-icon { flex-shrink: 0; font-size: 1.1rem; }
    .notice strong { font-weight: 600; }

    /* ── CARD ── */
    .card {
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      padding: 28px 30px 32px;
      margin-bottom: 20px;
    }
    .card-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--blue);
      margin-bottom: 22px;
      padding-bottom: 14px;
      border-bottom: 2px solid var(--bg);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-title-icon { font-size: 1.2rem; }

    /* ── FORM GRID ── */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px 24px;
    }
    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .field.full-width { grid-column: 1 / -1; }

    label {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    label .req { color: var(--warning); margin-left: 2px; }

    input[type="text"],
    input[type="number"],
    select {
      width: 100%;
      padding: 10px 14px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      font-size: 0.92rem;
      font-family: inherit;
      background: #fafbfc;
      color: var(--text);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }
    input[type="text"]:focus,
    input[type="number"]:focus,
    select:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(30,58,95,0.1);
      background: #fff;
    }
    input.has-warning,
    select.has-warning { border-color: var(--warning); }

    .field-note {
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    .field-error {
      font-size: 0.78rem;
      color: var(--warning);
      font-weight: 500;
      display: none;
    }
    .field-error.visible { display: block; }

    /* ── BULLET EDITOR ── */
    .bullet-editor {
      border: 1.5px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      background: #fafbfc;
    }
    .bullet-list {
      list-style: none;
      padding: 8px 12px;
      min-height: 70px;
    }
    .bullet-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 0;
      border-bottom: 1px solid var(--border);
    }
    .bullet-item:last-child { border-bottom: none; }
    .bullet-bullet {
      font-size: 0.85rem;
      color: var(--blue);
      font-weight: 700;
      flex-shrink: 0;
      width: 14px;
    }
    .bullet-input {
      flex: 1;
      border: none;
      background: transparent;
      font-size: 0.9rem;
      font-family: inherit;
      color: var(--text);
      outline: none;
      padding: 2px 0;
    }
    .bullet-remove {
      background: none;
      border: none;
      color: #ccc;
      cursor: pointer;
      font-size: 1.1rem;
      padding: 2px 6px;
      border-radius: 4px;
      transition: color 0.15s, background 0.15s;
      flex-shrink: 0;
    }
    .bullet-remove:hover { color: var(--warning); background: #fee2e2; }
    .bullet-empty {
      font-size: 0.85rem;
      color: #bbb;
      padding: 10px 2px;
      font-style: italic;
    }

    .bullet-controls {
      display: flex;
      justify-content: flex-end;
      padding: 7px 10px;
      background: #f0f3f7;
      border-top: 1px solid var(--border);
    }
    .btn-add-bullet {
      background: none;
      border: 1.5px dashed #c0cad8;
      border-radius: 6px;
      color: var(--text-muted);
      font-size: 0.8rem;
      font-family: inherit;
      font-weight: 500;
      padding: 5px 14px;
      cursor: pointer;
      transition: all 0.15s;
    }
    .btn-add-bullet:hover {
      border-color: var(--blue);
      color: var(--blue);
      background: rgba(30,58,95,0.04);
    }

    /* ── WARNING BADGE ── */
    .warning-badge {
      display: none;
      align-items: center;
      gap: 5px;
      font-size: 0.78rem;
      color: var(--warning);
      font-weight: 500;
      padding: 3px 8px;
      background: #fee2e2;
      border-radius: 20px;
      margin-top: 2px;
    }
    .warning-badge.visible { display: inline-flex; }

    /* ── BUTTONS ── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 13px 32px;
      font-size: 1rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      width: 100%;
    }
    .btn-primary:hover { background: var(--blue-hover); }
    .btn-primary:active { transform: scale(0.98); }

    /* ── OUTPUT ── */
    #output-section { display: none; }
    #output-section.visible { display: block; }

    .generated-row-wrap {
      position: relative;
      margin-bottom: 16px;
    }
    #generated-row {
      width: 100%;
      min-height: 90px;
      padding: 12px 14px 60px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      background: #f8f9fa;
      font-family: 'Courier New', Courier, monospace;
      font-size: 0.82rem;
      color: #333;
      resize: vertical;
      outline: none;
    }
    #generated-row:focus { border-color: var(--blue); }

    .copy-btn {
      position: absolute;
      bottom: 10px;
      right: 10px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 7px;
      padding: 7px 18px;
      font-size: 0.82rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.15s;
    }
    .copy-btn:hover { background: var(--blue-hover); }
    .copy-btn.copied { background: var(--success); }

    /* ── PREVIEW TABLE ── */
    .preview-table-wrap { overflow-x: auto; }
    table.preview-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
      margin-top: 4px;
    }
    table.preview-table th {
      background: var(--blue);
      color: #fff;
      padding: 8px 12px;
      text-align: left;
      font-weight: 600;
      white-space: nowrap;
    }
    table.preview-table td {
      padding: 8px 12px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
      color: var(--text);
      word-break: break-word;
    }
    table.preview-table tr:last-child td { border-bottom: none; }
    table.preview-table tr:nth-child(even) td { background: #f8fafc; }

    /* ── SUCCESS MESSAGE ── */
    .success-msg {
      display: none;
      align-items: center;
      gap: 8px;
      background: #f0fff4;
      border: 1.5px solid #68d391;
      border-radius: 8px;
      padding: 10px 16px;
      font-size: 0.88rem;
      color: var(--success);
      font-weight: 500;
      margin-bottom: 16px;
    }
    .success-msg.visible { display: flex; }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 20px;
      font-size: 0.8rem;
      color: var(--text-muted);
      border-top: 1px solid var(--border);
      margin-top: 8px;
    }
    footer strong { color: var(--blue); }
  </style>
</head>
<body>

<header>
  <h1>Job Offers Manager</h1>
  <p>Add a new job offer to the database</p>
</header>

<div class="container">

  <!-- Notice -->
  <div class="notice">
    <span class="notice-icon">⚠️</span>
    <div>
      <strong>Important — CSV format:</strong> Chaque champ est séparé par un <strong>point-virgule (;)</strong>.
      Les <strong>virgules sont interdites</strong> — elles sont automatiquement remplacées par des tirets (-).
    </div>
  </div>

  <!-- Form Card -->
  <div class="card">
    <div class="card-title">
      <span class="card-title-icon">📋</span> Job Offer Details
    </div>

    <form id="job-form" novalidate>

      <div class="form-grid">

        <!-- Job title -->
        <div class="field">
          <label for="job-title">Job title <span class="req">*</span></label>
          <input type="text" id="job-title" placeholder="e.g. Gardener" autocomplete="off">
          <div class="warning-badge" id="warn-job-title">
            <span>⚠️</span> Virgule remplacée par tiret
          </div>
        </div>

        <!-- Establishment -->
        <div class="field">
          <label for="establishment">Establishment <span class="req">*</span></label>
          <input type="text" id="establishment" placeholder="e.g. Red Cross KK" autocomplete="off">
          <div class="warning-badge" id="warn-establishment">
            <span>⚠️</span> Virgule remplacée par tiret
          </div>
        </div>

        <!-- City -->
        <div class="field">
          <label for="city">City <span class="req">*</span></label>
          <input type="text" id="city" placeholder="e.g. Kota Kinabalu" autocomplete="off">
          <div class="warning-badge" id="warn-city">
            <span>⚠️</span> Virgule remplacée par tiret
          </div>
        </div>

        <!-- District -->
        <div class="field">
          <label for="district">District <span class="req">*</span></label>
          <input type="text" id="district" placeholder="e.g. North-E" autocomplete="off">
          <div class="warning-badge" id="warn-district">
            <span>⚠️</span> Virgule remplacée par tiret
          </div>
        </div>

        <!-- Contract type -->
        <div class="field">
          <label for="contract-type">Contract type <span class="req">*</span></label>
          <select id="contract-type">
            <option value="">-- Select --</option>
            <option value="Full-Time">Full-Time</option>
            <option value="Part-Time">Part-Time</option>
            <option value="Freelance">Freelance</option>
            <option value="Internship">Internship</option>
            <option value="Temporary">Temporary</option>
          </select>
        </div>

        <!-- Salary -->
        <div class="field">
          <label for="salary">Annual base salary <span class="req">*</span></label>
          <input type="number" id="salary" placeholder="e.g. 38000" min="0" step="1">
          <span class="field-note">Nombre entier, sans virgule ni symbole</span>
        </div>

      </div><!-- /.form-grid -->

      <!-- SHORT DESCRIPTION -->
      <div class="field" style="margin-top: 22px;">
        <label>Short description <span class="req">*</span></label>
        <div class="bullet-editor" id="short-desc-editor">
          <ul class="bullet-list" id="short-desc-list">
            <li class="bullet-item">
              <span class="bullet-bullet">•</span>
              <input type="text" class="bullet-input" placeholder="Ajoutez un point..." autocomplete="off">
              <button type="button" class="bullet-remove" title="Supprimer">✕</button>
            </li>
          </ul>
          <div class="bullet-controls">
            <button type="button" class="btn-add-bullet" data-target="short-desc-list">+ Add bullet point</button>
          </div>
        </div>
        <div class="warning-badge" id="warn-short-desc">
          <span>⚠️</span> Virgule remplacée par tiret
        </div>
      </div>

      <!-- LONG DESCRIPTION -->
      <div class="field" style="margin-top: 20px;">
        <label>Long description <span class="req">*</span></label>
        <div class="bullet-editor" id="long-desc-editor">
          <ul class="bullet-list" id="long-desc-list">
            <li class="bullet-item">
              <span class="bullet-bullet">•</span>
              <input type="text" class="bullet-input" placeholder="Ajoutez un point..." autocomplete="off">
              <button type="button" class="bullet-remove" title="Supprimer">✕</button>
            </li>
          </ul>
          <div class="bullet-controls">
            <button type="button" class="btn-add-bullet" data-target="long-desc-list">+ Add bullet point</button>
          </div>
        </div>
        <div class="warning-badge" id="warn-long-desc">
          <span>⚠️</span> Virgule remplacée par tiret
        </div>
      </div>

      <!-- REQUIREMENTS -->
      <div class="field" style="margin-top: 20px;">
        <label>Requirements <span class="req">*</span></label>
        <div class="bullet-editor" id="requirements-editor">
          <ul class="bullet-list" id="requirements-list">
            <li class="bullet-item">
              <span class="bullet-bullet">•</span>
              <input type="text" class="bullet-input" placeholder="Ajoutez un point..." autocomplete="off">
              <button type="button" class="bullet-remove" title="Supprimer">✕</button>
            </li>
          </ul>
          <div class="bullet-controls">
            <button type="button" class="btn-add-bullet" data-target="requirements-list">+ Add bullet point</button>
          </div>
        </div>
        <div class="warning-badge" id="warn-requirements">
          <span>⚠️</span> Virgule remplacée par tiret
        </div>
      </div>

      <!-- SUBMIT -->
      <div style="margin-top: 28px;">
        <button type="submit" class="btn-primary" id="generate-btn">
          <span>📊</span> Generate Row
        </button>
      </div>

    </form>
  </div><!-- /.card -->

  <!-- Output Section -->
  <div id="output-section">
    <div class="success-msg" id="success-msg">
      <span>✅</span> Ligne générée avec succès — copiez-la et collez-la dans le Google Sheet DB_jobs.
    </div>

    <div class="card">
      <div class="card-title">
        <span class="card-title-icon">📄</span> Generated CSV Row
      </div>

      <div class="generated-row-wrap">
        <textarea id="generated-row" readonly placeholder="La ligne CSV apparaîtra ici..."></textarea>
        <button type="button" class="copy-btn" id="copy-btn">Copy to Clipboard</button>
      </div>

      <div class="preview-table-wrap">
        <table class="preview-table" id="preview-table">
          <thead>
            <tr>
              <th>Job title</th>
              <th>Establishment</th>
              <th>City</th>
              <th>District</th>
              <th>Contract type</th>
              <th>Annual base salary</th>
              <th>Short description</th>
              <th>Long description</th>
              <th>Requirements</th>
            </tr>
          </thead>
          <tbody id="preview-body">
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div><!-- /.container -->

<footer>
  Les données sont séparées par des <strong>point-virgules (;)</strong>. Collez la ligne générée dans le Google Sheet.<br>
  &copy; Job Offers Manager
</footer>

<script>
  /* ─────────────────────────────────────────────
     UTILITIES
  ───────────────────────────────────────────── */
  function sanitize(str) {
    // Remplace les virgules par des tirets pour protéger le format CSV
    return str.replace(/,/g, ' -').trim();
  }

  function showWarning(inputEl) {
    const badge = document.getElementById('warn-' + inputEl.id);
    if (badge) {
      badge.classList.add('visible');
      setTimeout(() => badge.classList.remove('visible'), 2500);
    }
  }

  /* ─────────────────────────────────────────────
     TEXT INPUTS — virgule auto-replacement
  ───────────────────────────────────────────── */
  const textInputs = ['job-title', 'establishment', 'city', 'district'];
  textInputs.forEach(id => {
    const el = document.getElementById(id);
    el.addEventListener('input', () => {
      if (el.value.includes(',')) {
        el.value = sanitize(el.value);
        showWarning(el);
      }
    });
  });

  /* ─────────────────────────────────────────────
     BULLET LIST EDITOR
  ───────────────────────────────────────────── */
  function addBulletItem(listId) {
    const list = document.getElementById(listId);
    // Supprime le placeholder vide s'il existe
    const placeholder = list.querySelector('.bullet-empty');
    if (placeholder) placeholder.remove();

    const li = document.createElement('li');
    li.className = 'bullet-item';
    li.innerHTML = `
      <span class="bullet-bullet">•</span>
      <input type="text" class="bullet-input" placeholder="Ajoutez un point..." autocomplete="off">
      <button type="button" class="bullet-remove" title="Supprimer">✕</button>
    `;

    // Bind remove
    li.querySelector('.bullet-remove').addEventListener('click', () => {
      li.remove();
      maybeAddPlaceholder(listId);
    });

    // Bind comma sanitizer
    li.querySelector('.bullet-input').addEventListener('input', (e) => {
      if (e.target.value.includes(',')) {
        e.target.value = sanitize(e.target.value);
        const badge = document.getElementById('warn-' + listId);
        if (badge) {
          badge.classList.add('visible');
          setTimeout(() => badge.classList.remove('visible'), 2500);
        }
      }
    });

    list.appendChild(li);
    li.querySelector('.bullet-input').focus();
  }

  function getBulletText(listId) {
    const list = document.getElementById(listId);
    const inputs = list.querySelectorAll('.bullet-input');
    const texts = Array.from(inputs)
      .map(i => i.value.trim())
      .filter(t => t.length > 0);
    return texts.join(' • ');
  }

  function maybeAddPlaceholder(listId) {
    const list = document.getElementById(listId);
    if (list.querySelectorAll('.bullet-input').length === 0) {
      list.innerHTML = '<li class="bullet-empty">Aucun point — cliquez "+ Add bullet point"</li>';
    }
  }

  // Bind "+ Add bullet point" buttons
  document.querySelectorAll('.btn-add-bullet').forEach(btn => {
    btn.addEventListener('click', () => {
      addBulletItem(btn.dataset.target);
    });
  });

  // Bind initial remove buttons
  document.querySelectorAll('.bullet-remove').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.bullet-item').remove();
      // rien à faire pour le placeholder car on a déjà 1 item
    });
  });

  // Bind comma sanitizers sur les bullets existants
  document.querySelectorAll('.bullet-input').forEach(input => {
    input.addEventListener('input', (e) => {
      if (e.target.value.includes(',')) {
        e.target.value = sanitize(e.target.value);
        // pas de badge pour les bullets (trop complexe), juste le replacement
      }
    });
  });

  /* ─────────────────────────────────────────────
     VALIDATION
  ───────────────────────────────────────────── */
  function showFieldError(id, msg) {
    let el = document.getElementById('err-' + id);
    if (!el) {
      el = document.createElement('div');
      el.id = 'err-' + id;
      el.className = 'field-error visible';
      const input = document.getElementById(id);
      if (input) input.parentElement.appendChild(el);
    }
    el.textContent = msg;
  }

  function clearFieldErrors() {
    document.querySelectorAll('.field-error').forEach(e => e.remove());
  }

  function validate() {
    clearFieldErrors();
    let valid = true;

    const ids = ['job-title', 'establishment', 'city', 'district', 'contract-type', 'salary'];
    const labels = {
      'job-title': 'Job title',
      'establishment': 'Establishment',
      'city': 'City',
      'district': 'District',
      'contract-type': 'Contract type',
      'salary': 'Annual base salary'
    };

    ids.forEach(id => {
      const el = document.getElementById(id);
      if (!el.value.trim()) {
        showFieldError(id, labels[id] + ' est requis');
        el.classList.add('has-warning');
        valid = false;
      } else {
        el.classList.remove('has-warning');
      }
    });

    // Bullet lists
    ['short-desc-list', 'long-desc-list', 'requirements-list'].forEach(listId => {
      const texts = Array.from(document.querySelectorAll('#' + listId + ' .bullet-input'))
        .map(i => i.value.trim())
        .filter(t => t);
      if (texts.length === 0) {
        const badge = document.getElementById('warn-' + listId);
        if (badge) badge.classList.add('visible');
        valid = false;
      } else {
        const badge = document.getElementById('warn-' + listId);
        if (badge) badge.classList.remove('visible');
      }
    });

    return valid;
  }

  /* ─────────────────────────────────────────────
     GENERATE ROW
  ───────────────────────────────────────────── */
  function escapeCSV(val) {
    // Wrap en guillemets si contient ; ou "
    const s = String(val);
    if (s.includes(';') || s.includes('"') || s.includes('\n')) {
      return '"' + s.replace(/"/g, '""') + '"';
    }
    return s;
  }

  function generateCSV() {
    const jobTitle    = sanitize(document.getElementById('job-title').value.trim());
    const establishment = sanitize(document.getElementById('establishment').value.trim());
    const city        = sanitize(document.getElementById('city').value.trim());
    const district    = sanitize(document.getElementById('district').value.trim());
    const contract   = document.getElementById('contract-type').value.trim();
    const salary      = document.getElementById('salary').value.trim();
    const shortDesc   = getBulletText('short-desc-list');
    const longDesc    = getBulletText('long-desc-list');
    const requirements = getBulletText('requirements-list');

    const row = [
      escapeCSV(jobTitle),
      escapeCSV(establishment),
      escapeCSV(city),
      escapeCSV(district),
      escapeCSV(contract),
      escapeCSV(salary),
      escapeCSV(shortDesc),
      escapeCSV(longDesc),
      escapeCSV(requirements)
    ].join(';');

    return row;
  }

  function updatePreview() {
    const tbody = document.getElementById('preview-body');
    tbody.innerHTML = '';

    const cells = [
      document.getElementById('job-title').value.trim(),
      document.getElementById('establishment').value.trim(),
      document.getElementById('city').value.trim(),
      document.getElementById('district').value.trim(),
      document.getElementById('contract-type').value.trim(),
      document.getElementById('salary').value.trim(),
      getBulletText('short-desc-list'),
      getBulletText('long-desc-list'),
      getBulletText('requirements-list')
    ].map(v => `<td>${v.replace(/</g, '<').replace(/>/g, '>')}</td>`).join('');

    tbody.innerHTML = `<tr>${cells}</tr>`;
  }

  /* ─────────────────────────────────────────────
     FORM SUBMIT
  ───────────────────────────────────────────── */
  document.getElementById('job-form').addEventListener('submit', (e) => {
    e.preventDefault();

    if (!validate()) {
      // Scroll to first error
      const firstErr = document.querySelector('.has-warning, .field-error.visible');
      if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const row = generateCSV();
    const output = document.getElementById('generated-row');
    output.value = row;
    updatePreview();

    const section = document.getElementById('output-section');
    section.classList.add('visible');
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  /* ─────────────────────────────────────────────
     COPY TO CLIPBOARD
  ───────────────────────────────────────────── */
  document.getElementById('copy-btn').addEventListener('click', () => {
    const text = document.getElementById('generated-row').value;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-btn');
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'Copy to Clipboard';
        btn.classList.remove('copied');
      }, 2000);
    }).catch(() => {
      // Fallback
      document.getElementById('generated-row').select();
      document.execCommand('copy');
    });
  });
</script>

