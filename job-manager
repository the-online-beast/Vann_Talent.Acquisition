<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job Offers Manager</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #1e3a5f;
      --blue-light: #2a5080;
      --blue-hover: #163049;
      --bg: #f4f6f9;
      --card-bg: #ffffff;
      --text: #1a1a2e;
      --text-muted: #6b7280;
      --border: #e2e8f0;
      --warning: #e53e3e;
      --success: #2f855a;
      --radius: 12px;
      --shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      background: var(--blue);
      color: #fff;
      padding: 32px 24px 28px;
      text-align: center;
    }
    header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }
    header p {
      font-size: 0.95rem;
      opacity: 0.8;
      font-weight: 400;
    }

    /* ── CONTAINER ── */
    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 28px 20px 48px;
    }

    /* ── TABS ── */
    .tabs {
      display: flex;
      gap: 12px;
      margin-bottom: 24px;
      border-bottom: 2px solid var(--border);
    }
    .tab-btn {
      background: none;
      border: none;
      padding: 12px 20px;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-muted);
      cursor: pointer;
      border-bottom: 3px solid transparent;
      transition: all 0.2s;
      font-family: inherit;
    }
    .tab-btn.active {
      color: var(--blue);
      border-bottom-color: var(--blue);
    }
    .tab-btn:hover { color: var(--blue); }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* ── NOTICE ── */
    .notice {
      background: #fff8e6;
      border: 1.5px solid #f0c040;
      border-radius: var(--radius);
      padding: 12px 18px;
      font-size: 0.88rem;
      color: #7a5c00;
      margin-bottom: 24px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
    }
    .notice-icon { flex-shrink: 0; font-size: 1.1rem; }
    .notice strong { font-weight: 600; }

    /* ── CARD ── */
    .card {
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      padding: 28px 30px 32px;
      margin-bottom: 20px;
    }
    .card-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--blue);
      margin-bottom: 22px;
      padding-bottom: 14px;
      border-bottom: 2px solid var(--bg);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-title-icon { font-size: 1.2rem; }

    /* ── FORM GRID ── */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px 24px;
    }
    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .field.full-width { grid-column: 1 / -1; }

    label {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    label .req { color: var(--warning); margin-left: 2px; }

    input[type="text"],
    input[type="number"],
    select,
    textarea {
      width: 100%;
      padding: 10px 14px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      font-size: 0.92rem;
      font-family: inherit;
      background: #fafbfc;
      color: var(--text);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }
    input[type="text"]:focus,
    input[type="number"]:focus,
    select:focus,
    textarea:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(30,58,95,0.1);
      background: #fff;
    }

    textarea {
      resize: vertical;
      min-height: 100px;
      font-family: inherit;
    }

    .field-note {
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    /* ── BULLET EDITOR ── */
    .bullet-editor {
      border: 1.5px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      background: #fafbfc;
    }
    .bullet-list {
      list-style: none;
      padding: 8px 12px;
      min-height: 70px;
    }
    .bullet-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 0;
      border-bottom: 1px solid var(--border);
    }
    .bullet-item:last-child { border-bottom: none; }
    .bullet-bullet {
      font-size: 0.85rem;
      color: var(--blue);
      font-weight: 700;
      flex-shrink: 0;
      width: 14px;
    }
    .bullet-input {
      flex: 1;
      border: none;
      background: transparent;
      font-size: 0.9rem;
      font-family: inherit;
      color: var(--text);
      outline: none;
      padding: 2px 0;
    }
    .bullet-remove {
      background: none;
      border: none;
      color: #ccc;
      cursor: pointer;
      font-size: 1.1rem;
      padding: 2px 6px;
      border-radius: 4px;
      transition: color 0.15s, background 0.15s;
      flex-shrink: 0;
    }
    .bullet-remove:hover { color: var(--warning); background: #fee2e2; }

    .bullet-controls {
      display: flex;
      justify-content: flex-end;
      padding: 7px 10px;
      background: #f0f3f7;
      border-top: 1px solid var(--border);
    }
    .btn-add-bullet {
      background: none;
      border: 1.5px dashed #c0cad8;
      border-radius: 6px;
      color: var(--text-muted);
      font-size: 0.8rem;
      font-family: inherit;
      font-weight: 500;
      padding: 5px 14px;
      cursor: pointer;
      transition: all 0.15s;
    }
    .btn-add-bullet:hover {
      border-color: var(--blue);
      color: var(--blue);
      background: rgba(30,58,95,0.04);
    }

    /* ── BUTTONS ── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 13px 32px;
      font-size: 1rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      width: 100%;
    }
    .btn-primary:hover { background: var(--blue-hover); }
    .btn-primary:active { transform: scale(0.98); }
    .btn-primary:disabled {
      background: #ccc;
      cursor: not-allowed;
    }

    .btn-small {
      padding: 6px 12px;
      font-size: 0.8rem;
      border-radius: 6px;
      border: none;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: inherit;
    }

    .btn-delete {
      background: #fee2e2;
      color: var(--warning);
    }
    .btn-delete:hover { background: #fccccb; }

    .btn-toggle {
      background: #e2f7ee;
      color: var(--success);
    }
    .btn-toggle:hover { background: #cdf1e5; }
    .btn-toggle.inactive {
      background: #fee2e2;
      color: var(--warning);
    }
    .btn-toggle.inactive:hover { background: #fccccb; }

    /* ── SUCCESS MESSAGE ── */
    .success-msg {
      display: none;
      align-items: center;
      gap: 8px;
      background: #f0fff4;
      border: 1.5px solid #68d391;
      border-radius: 8px;
      padding: 10px 16px;
      font-size: 0.88rem;
      color: var(--success);
      font-weight: 500;
      margin-bottom: 16px;
    }
    .success-msg.visible { display: flex; }

    .error-msg {
      display: none;
      align-items: center;
      gap: 8px;
      background: #fee2e2;
      border: 1.5px solid #fc8181;
      border-radius: 8px;
      padding: 10px 16px;
      font-size: 0.88rem;
      color: var(--warning);
      font-weight: 500;
      margin-bottom: 16px;
    }
    .error-msg.visible { display: flex; }

    /* ── JOBS TABLE ── */
    .jobs-table-wrap {
      overflow-x: auto;
    }
    table.jobs-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
      margin-top: 4px;
    }
    table.jobs-table th {
      background: var(--blue);
      color: #fff;
      padding: 10px 12px;
      text-align: left;
      font-weight: 600;
      white-space: nowrap;
    }
    table.jobs-table td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    table.jobs-table tr:last-child td { border-bottom: none; }
    table.jobs-table tr:nth-child(even) td { background: #f8fafc; }

    .job-title-cell { font-weight: 600; color: var(--blue); }
    .job-meta { font-size: 0.75rem; color: var(--text-muted); }

    .action-buttons {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .loading {
      text-align: center;
      padding: 20px;
      color: var(--text-muted);
    }

    .spinner {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid var(--border);
      border-top-color: var(--blue);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 20px;
      font-size: 0.8rem;
      color: var(--text-muted);
      border-top: 1px solid var(--border);
      margin-top: 8px;
    }
  </style>
</head>
<body>

<header>
  <h1>Job Offers Manager</h1>
  <p>Manage job offers and database</p>
</header>

<div class="container">

  <!-- TABS -->
  <div class="tabs">
    <button class="tab-btn active" data-tab="create">➕ Create Offer</button>
    <button class="tab-btn" data-tab="manage">📋 Manage Offers</button>
  </div>

  <!-- ========================================
       TAB 1: CREATE OFFER
       ======================================== -->
  <div id="create" class="tab-content active">

    <div class="notice">
      <span class="notice-icon">ℹ️</span>
      <div>
        <strong>Short Description & Long Description:</strong> Collez le texte de la Job Description existante. Les retours à la ligne et textes longs sont acceptés.
      </div>
    </div>

    <div class="success-msg" id="create-success">
      <span>✅</span> Offre créée avec succès !
    </div>
    <div class="error-msg" id="create-error">
      <span>❌</span> <span id="error-text"></span>
    </div>

    <div class="card">
      <div class="card-title">
        <span class="card-title-icon">📋</span> Job Offer Details
      </div>

      <form id="job-form" novalidate>

        <div class="form-grid">

          <!-- Job title -->
          <div class="field">
            <label for="job-title">Job title <span class="req">*</span></label>
            <input type="text" id="job-title" placeholder="e.g. Gardener" autocomplete="off">
          </div>

          <!-- Establishment -->
          <div class="field">
            <label for="establishment">Establishment <span class="req">*</span></label>
            <input type="text" id="establishment" placeholder="e.g. Red Cross KK" autocomplete="off">
          </div>

          <!-- City -->
          <div class="field">
            <label for="city">City <span class="req">*</span></label>
            <input type="text" id="city" placeholder="e.g. Kota Kinabalu" autocomplete="off">
          </div>

          <!-- District -->
          <div class="field">
            <label for="district">District <span class="req">*</span></label>
            <input type="text" id="district" placeholder="e.g. North-E" autocomplete="off">
          </div>

          <!-- Contract type -->
          <div class="field">
            <label for="contract-type">Contract type <span class="req">*</span></label>
            <select id="contract-type">
              <option value="">-- Select --</option>
              <option value="Full-Time">Full-Time</option>
              <option value="Part-Time">Part-Time</option>
              <option value="Freelance">Freelance</option>
              <option value="Internship">Internship</option>
              <option value="Temporary">Temporary</option>
            </select>
          </div>

          <!-- Salary -->
          <div class="field">
            <label for="salary">Annual base salary <span class="req">*</span></label>
            <input type="number" id="salary" placeholder="e.g. 38000" min="0" step="1">
            <span class="field-note">Nombre entier, sans virgule</span>
          </div>

        </div>

        <!-- SHORT DESCRIPTION -->
        <div class="field" style="margin-top: 22px;">
          <label for="short-description">Short description <span class="req">*</span></label>
          <textarea id="short-description" placeholder="Résumé court de l'offre (copier-coller accepté)"></textarea>
          <span class="field-note">Texte court, max 300 caractères</span>
        </div>

        <!-- LONG DESCRIPTION -->
        <div class="field" style="margin-top: 20px;">
          <label for="long-description">Long description <span class="req">*</span></label>
          <textarea id="long-description" placeholder="Description complète (copier-coller accepté)"></textarea>
          <span class="field-note">Texte plus détaillé, accepte les retours à la ligne</span>
        </div>

        <!-- REQUIREMENTS -->
        <div class="field" style="margin-top: 20px;">
          <label>Requirements <span class="req">*</span></label>
          <div class="bullet-editor" id="requirements-editor">
            <ul class="bullet-list" id="requirements-list">
              <li class="bullet-item">
                <span class="bullet-bullet">•</span>
                <input type="text" class="bullet-input" placeholder="Ajoutez une exigence..." autocomplete="off">
                <button type="button" class="bullet-remove" title="Supprimer">✕</button>
              </li>
            </ul>
            <div class="bullet-controls">
              <button type="button" class="btn-add-bullet" data-target="requirements-list">+ Add requirement</button>
            </div>
          </div>
        </div>

        <!-- SUBMIT -->
        <div style="margin-top: 28px;">
          <button type="submit" class="btn-primary" id="submit-btn">
            <span>✅</span> Submit Offer
          </button>
        </div>

      </form>
    </div>

  </div><!-- /.tab-content create -->

  <!-- ========================================
       TAB 2: MANAGE OFFERS
       ======================================== -->
  <div id="manage" class="tab-content">

    <div class="card">
      <div class="card-title">
        <span class="card-title-icon">📊</span> Active Job Offers
      </div>

      <div id="manage-loading" class="loading">
        <div class="spinner"></div>
        <p style="margin-top: 10px;">Chargement des offres...</p>
      </div>

      <div id="manage-content" style="display: none;">
        <div class="jobs-table-wrap">
          <table class="jobs-table">
            <thead>
              <tr>
                <th>Titre</th>
                <th>Établissement</th>
                <th>Ville</th>
                <th>Contrat</th>
                <th>Salaire</th>
                <th>Statut</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="jobs-tbody">
            </tbody>
          </table>
        </div>
      </div>

      <div id="manage-empty" style="display: none; text-align: center; padding: 40px 20px; color: var(--text-muted);">
        <p>Aucune offre trouvée.</p>
      </div>
    </div>

  </div><!-- /.tab-content manage -->

</div><!-- /.container -->

<footer>
  Job Offers Manager — Vann can manage and create offers easily.<br>
  Data is automatically synced with Google Sheets DB_jobs.
</footer>

<script>
  /* ═══════════════════════════════════════════
     CONFIGURATION
     ═══════════════════════════════════════════ */
  const WEBHOOK_URL = 'https://n8n.strength-os.tech/webhook/job-managment';
  const CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vRRkoXsy6784kZL208ovB7oJojrLH2hwXuEysJ9ldNB019THeB6oGHTgNHE5gVUXv5SLVYfH-KPr24o/pub?output=csv';

  /* ═══════════════════════════════════════════
     TAB SWITCHING
     ═══════════════════════════════════════════ */
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tabName = btn.dataset.tab;

      // Désactiver tous les tabs
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

      // Activer le tab cliqué
      btn.classList.add('active');
      document.getElementById(tabName).classList.add('active');

      // Si tab manage, charger les offres
      if (tabName === 'manage') {
        loadJobs();
      }
    });
  });

  /* ═══════════════════════════════════════════
     BULLET LIST EDITOR
     ═══════════════════════════════════════════ */
  function addBulletItem(listId) {
    const list = document.getElementById(listId);
    const li = document.createElement('li');
    li.className = 'bullet-item';
    li.innerHTML = `
      <span class="bullet-bullet">•</span>
      <input type="text" class="bullet-input" placeholder="Ajoutez une exigence..." autocomplete="off">
      <button type="button" class="bullet-remove" title="Supprimer">✕</button>
    `;

    li.querySelector('.bullet-remove').addEventListener('click', (e) => {
      e.preventDefault();
      li.remove();
    });

    list.appendChild(li);
    li.querySelector('.bullet-input').focus();
  }

  function getBulletText(listId) {
    const list = document.getElementById(listId);
    const inputs = list.querySelectorAll('.bullet-input');
    const texts = Array.from(inputs)
      .map(i => i.value.trim())
      .filter(t => t.length > 0);
    return texts.join(' • ');
  }

  document.querySelectorAll('.btn-add-bullet').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      addBulletItem(btn.dataset.target);
    });
  });

  document.querySelectorAll('.bullet-remove').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      btn.closest('.bullet-item').remove();
    });
  });

  /* ═══════════════════════════════════════════
     VALIDATION
     ═══════════════════════════════════════════ */
  function validateForm() {
    const required = ['job-title', 'establishment', 'city', 'district', 'contract-type', 'salary', 'short-description', 'long-description'];
    let valid = true;

    required.forEach(id => {
      const el = document.getElementById(id);
      const val = el.value.trim();
      if (!val) {
        el.style.borderColor = 'var(--warning)';
        valid = false;
      } else {
        el.style.borderColor = '';
      }
    });

    const requirements = getBulletText('requirements-list');
    if (!requirements) {
      valid = false;
      showError('Requirements cannot be empty');
      return valid;
    }

    return valid;
  }

  /* ═══════════════════════════════════════════
     MESSAGES
     ═══════════════════════════════════════════ */
  function showSuccess(msg = 'Offre créée avec succès !') {
    const el = document.getElementById('create-success');
    el.textContent = msg;
    el.classList.add('visible');
    setTimeout(() => el.classList.remove('visible'), 3500);
  }

  function showError(msg) {
    const el = document.getElementById('create-error');
    const textEl = document.getElementById('error-text');
    textEl.textContent = msg;
    el.classList.add('visible');
    setTimeout(() => el.classList.remove('visible'), 4000);
  }

  /* ═══════════════════════════════════════════
     SUBMIT FORM
     ═══════════════════════════════════════════ */
  document.getElementById('job-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!validateForm()) {
      showError('Veuillez remplir tous les champs obligatoires');
      return;
    }

    const submitBtn = document.getElementById('submit-btn');
    submitBtn.disabled = true;
    submitBtn.textContent = '⏳ Envoi...';

    const payload = {
      'Job title': document.getElementById('job-title').value.trim(),
      'Establishment': document.getElementById('establishment').value.trim(),
      'City': document.getElementById('city').value.trim(),
      'District': document.getElementById('district').value.trim(),
      'Contract type': document.getElementById('contract-type').value.trim(),
      'Annual base salary': document.getElementById('salary').value.trim(),
      'Short description': document.getElementById('short-description').value.trim(),
      'Long description': document.getElementById('long-description').value.trim(),
      'Requirements': getBulletText('requirements-list'),
      'Status': 'active'
    };

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        throw new Error(`Erreur ${response.status}`);
      }

      // Reset form
      document.getElementById('job-form').reset();
      // Reset requirements
      document.getElementById('requirements-list').innerHTML = `
        <li class="bullet-item">
          <span class="bullet-bullet">•</span>
          <input type="text" class="bullet-input" placeholder="Ajoutez une exigence..." autocomplete="off">
          <button type="button" class="bullet-remove" title="Supprimer">✕</button>
        </li>
      `;

      showSuccess('✅ Offre créée et synchronisée avec Google Sheets !');
    } catch (error) {
      showError(`Erreur d'envoi: ${error.message}`);
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span>✅</span> Submit Offer';
    }
  });

  /* ═══════════════════════════════════════════
     LOAD JOBS FROM CSV
     ═══════════════════════════════════════════ */
  async function loadJobs() {
    const loading = document.getElementById('manage-loading');
    const content = document.getElementById('manage-content');
    const empty = document.getElementById('manage-empty');
    const tbody = document.getElementById('jobs-tbody');

    loading.style.display = 'block';
    content.style.display = 'none';
    empty.style.display = 'none';

    try {
      const response = await fetch(CSV_URL);
      const csvText = await response.text();
      const jobs = parseCSV(csvText);

      if (jobs.length === 0) {
        loading.style.display = 'none';
        empty.style.display = 'block';
        return;
      }

      tbody.innerHTML = '';
      jobs.forEach((job, idx) => {
        const tr = document.createElement('tr');
        const status = job.Status && job.Status.toLowerCase() === 'active' ? 'active' : 'inactive';

        tr.innerHTML = `
          <td class="job-title-cell">${escapeHtml(job['Job title'] || '')}</td>
          <td>
            <div>${escapeHtml(job.Establishment || '')}</div>
            <div class="job-meta">${escapeHtml(job.City || '')}</div>
          </td>
          <td>${escapeHtml(job.City || '')}</td>
          <td>${escapeHtml(job['Contract type'] || '')}</td>
          <td>${escapeHtml(job['Annual base salary'] || '')}</td>
          <td>
            <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; ${status === 'active' ? 'background: #e2f7ee; color: var(--success)' : 'background: #fee2e2; color: var(--warning)'}">
              ${status === 'active' ? 'Active' : 'Inactive'}
            </span>
          </td>
          <td>
            <div class="action-buttons">
              <button class="btn-small btn-toggle ${status === 'inactive' ? 'inactive' : ''}` data-idx="${idx}" data-status="${status}">
                ${status === 'active' ? '👁️ Hide' : '🚫 Show'}
              </button>
              <button class="btn-small btn-delete" data-idx="${idx}">🗑️ Delete</button>
            </div>
          </td>
        `;

        tbody.appendChild(tr);
      });

      // Bind toggle buttons
      tbody.querySelectorAll('.btn-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.idx);
          const currentStatus = btn.dataset.status;
          const newStatus = currentStatus === 'active' ? 'inactive' : 'active';
          toggleJobStatus(jobs[idx], newStatus);
        });
      });

      // Bind delete buttons
      tbody.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.idx);
          deleteJob(jobs[idx]);
        });
      });

      loading.style.display = 'none';
      content.style.display = 'block';
    } catch (error) {
      console.error('Erreur chargement CSV:', error);
      loading.style.display = 'none';
      empty.style.display = 'block';
    }
  }

  /* ═══════════════════════════════════════════
     PARSE CSV
     ═══════════════════════════════════════════ */
  function parseCSV(csvText) {
    const lines = csvText.trim().split('\n');
    if (lines.length === 0) return [];

    const headers = parseCSVLine(lines[0]);
    const jobs = [];

    for (let i = 1; i < lines.length; i++) {
      const values = parseCSVLine(lines[i]);
      const job = {};
      headers.forEach((header, idx) => {
        job[header.trim()] = values[idx] ? values[idx].trim() : '';
      });
      if (job['Job title']) {
        jobs.push(job);
      }
    }

    return jobs;
  }

  function parseCSVLine(line) {
    const result = [];
    let current = '';
    let insideQuotes = false;

    for (let i = 0; i < line.length; i++) {
      const char = line[i];
      const nextChar = line[i + 1];

      if (char === '"') {
        if (insideQuotes && nextChar === '"') {
          current += '"';
          i++;
        } else {
          insideQuotes = !insideQuotes;
        }
      } else if (char === ',' && !insideQuotes) {
        result.push(current);
        current = '';
      } else {
        current += char;
      }
    }

    result.push(current);
    return result;
  }

  /* ═══════════════════════════════════════════
     TOGGLE JOB STATUS
     ═══════════════════════════════════════════ */
  async function toggleJobStatus(job, newStatus) {
    const payload = { ...job, Status: newStatus };

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) throw new Error(`Erreur ${response.status}`);

      showSuccess(`Statut changé en ${newStatus === 'active' ? 'Active' : 'Inactive'}`);
      loadJobs();
    } catch (error) {
      showError(`Erreur: ${error.message}`);
    }
  }

  /* ═══════════════════════════════════════════
     DELETE JOB (mark as deleted or remove)
     ═══════════════════════════════════════════ */
  async function deleteJob(job) {
    if (!confirm(`Supprimer l'offre "${job['Job title']}" ?`)) return;

    // Option 1: Supprimer complètement (à adapter selon n8n)
    // Option 2: Marquer comme inactive + ajouter un flag delete
    const payload = { ...job, Status: 'deleted' };

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) throw new Error(`Erreur ${response.status}`);

      showSuccess('Offre supprimée');
      loadJobs();
    } catch (error) {
      showError(`Erreur suppression: ${error.message}`);
    }
  }

  /* ═══════════════════════════════════════════
     UTILITIES
     ═══════════════════════════════════════════ */
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
</script>

